# .gitignore — Prevent Secrets from Being Committed

# ═══════════════════════════════════════════════════════════════════════════════
# Environment Variables (SECRETS — NEVER COMMIT)
# ═══════════════════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.*.prod
*.pem
*.key

# ═══════════════════════════════════════════════════════════════════════════════
# Node.js & npm
# ═══════════════════════════════════════════════════════════════════════════════
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.eslintcache
package-lock.json
yarn.lock

# ═══════════════════════════════════════════════════════════════════════════════
# Build Output
# ═══════════════════════════════════════════════════════════════════════════════
dist/
build/
out/
.next/
.nuxt/

# ═══════════════════════════════════════════════════════════════════════════════
# IDE & Editor
# ═══════════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ═══════════════════════════════════════════════════════════════════════════════
# Logs
# ═══════════════════════════════════════════════════════════════════════════════
logs/
*.log
lerna-debug.log*

# ═══════════════════════════════════════════════════════════════════════════════
# Temporary Files
# ═══════════════════════════════════════════════════════════════════════════════
tmp/
temp/
*.tmp
*.bak
*.cache

# ═══════════════════════════════════════════════════════════════════════════════
# OS Specific
# ═══════════════════════════════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# ═══════════════════════════════════════════════════════════════════════════════
# React / Vite Specific
# ═══════════════════════════════════════════════════════════════════════════════
web/dist/
web/build/
web/.env.local

# ═══════════════════════════════════════════════════════════════════════════════
# Express / Node Specific
# ═══════════════════════════════════════════════════════════════════════════════
server/dist/
server/.env
server/.env.local

# ═══════════════════════════════════════════════════════════════════════════════
# Docker
# ═══════════════════════════════════════════════════════════════════════════════
.dockerignore

# ═══════════════════════════════════════════════════════════════════════════════
# System Files (macOS)
# ═══════════════════════════════════════════════════════════════════════════════
.AppleDouble
.LSOverride
.TemporaryItems
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# ═══════════════════════════════════════════════════════════════════════════════
# Misc
# ═══════════════════════════════════════════════════════════════════════════════
.venv/
venv/
.Python
*.egg-info/
.coverage
coverage/
htmlcov/
