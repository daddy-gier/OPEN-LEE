# ── Anthropic Claude (Required for Brain + /api/claude) ─────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Server ───────────────────────────────────────────────────────
PORT=3001

# ── OpenClaw Muscles via Ollama (no API key required) ───────────
# Run: ollama serve  (then: ollama pull qwen2.5-coder:14b qwen3:14b mistral:7b)
OLLAMA_BASE_URL=http://localhost:11434/v1

OPENCLAW_CHARLIE_MODEL=qwen2.5-coder:14b
OPENCLAW_SCOUT_MODEL=qwen3:14b
OPENCLAW_SPEEDY_MODEL=mistral:7b

# ── Endpoints available after server starts ──────────────────────
#  GET  /api/openclaw/status          — check brain + all muscles
#  POST /api/openclaw/brain           — Claude orchestrator
#  POST /api/openclaw/charlie         — coder (UE5 C++)
#  POST /api/openclaw/scout           — researcher (NPC/faction)
#  POST /api/openclaw/speedy          — fast tasks / summaries
